# slidekit configuration. Copy to .env (gitignored) or set as real env vars.
# All values shown are the defaults.

# --- Binding ---
PORT=4030
HOST=0.0.0.0                      # 127.0.0.1 when running behind a reverse proxy

# --- Logging ---
LOG_LEVEL=info                    # debug | info | warn | error
LOG_FORMAT=json                   # json | pretty

# --- Auth ---
# Comma-separated API keys. When non-empty, POST /render requires a valid key
# (Authorization: Bearer <key> or X-API-Key: <key>). STRONGLY recommended before
# exposing the service — see SECURITY.md (rendering runs code).
SLIDEKIT_API_KEYS=
SLIDEKIT_REQUIRE_AUTH_ALL=0       # 1 = require a key on every route except /health
SLIDEKIT_TRUST_PROXY=0            # 1 = derive client IP from X-Forwarded-For (behind a trusted proxy only)

# --- Rate limiting (in-memory, per key/IP) ---
SLIDEKIT_RATE_LIMIT_MAX=30        # max /render requests per window; 0 disables
SLIDEKIT_RATE_LIMIT_WINDOW_MS=60000

# --- Build hardening ---
SLIDEKIT_MAX_BODY_BYTES=1048576   # max upload size (bytes) -> 413
SLIDEKIT_BUILD_TIMEOUT_MS=120000  # kill a build (whole process group) after this -> 504
SLIDEKIT_BUILD_CONCURRENCY=1      # keep 1 (style.css is shared mutable state)
SLIDEKIT_BUILD_QUEUE_MAX=20       # queued builds before 503
SLIDEKIT_QUEUE_TIMEOUT_MS=30000   # max wait in the build queue before 503
SLIDEKIT_JANITOR_INTERVAL_MS=0    # periodic stale-temp sweep; 0 disables

# --- HTTP timeouts (slow-loris / hung upload guard) ---
SLIDEKIT_REQUEST_TIMEOUT_MS=130000  # http.Server.requestTimeout; 0 off
SLIDEKIT_HEADERS_TIMEOUT_MS=15000   # http.Server.headersTimeout; 0 off

# --- Render cache (identical Markdown+theme served from memory) ---
SLIDEKIT_CACHE_MAX=50             # cached deck builds; 0 disables
SLIDEKIT_CACHE_TTL_MS=0           # cache entry TTL; 0 = never expire

# --- Async jobs + webhook (POST /render?async=1) ---
SLIDEKIT_JOBS_MAX=100             # max retained jobs/results
SLIDEKIT_JOB_TTL_MS=600000        # job + result lifetime
SLIDEKIT_WEBHOOK_ALLOW=           # comma-separated callback host allowlist; empty = webhooks off

# --- Response polish ---
SLIDEKIT_COMPRESSION=1            # gzip/deflate/br compress responses; 0 disables
SLIDEKIT_CORS_ORIGIN=            # Access-Control-Allow-Origin (e.g. *); empty = no CORS

# --- Misc ---
SLIDEKIT_DEFAULT_THEME=neutral
# Slidev base theme (an installed npm theme). An uploaded deck's own `theme:` is
# normalized to this, so an unknown theme can't break the build. The visual look
# is the CSS overlay selected via ?theme=.
SLIDEKIT_BASE_THEME=seriph
# SLIDEKIT_THEMES_DIR=/abs/path/to/themes
# SLIDEKIT_WORK_DIR=/abs/path/to/scratch
SLIDEKIT_SHUTDOWN_GRACE_MS=10000  # drain in-flight build on SIGTERM before exit
